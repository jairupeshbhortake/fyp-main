# ── SkyTraq Analytics – Environment Variables ──
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Backend
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./skytraq.db
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: PostgreSQL (comment out DATABASE_URL above)
# DATABASE_URL=postgresql://skytraq:password@db:5432/skytraq
# POSTGRES_PASSWORD=change-me

# Frontend (build-time)
VITE_API_BASE_URL=http://localhost:8000

# Docker (prod)
GITHUB_REPOSITORY=youruser/skytraq-analytics
IMAGE_TAG=latest
